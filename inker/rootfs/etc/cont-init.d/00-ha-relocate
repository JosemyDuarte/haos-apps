#!/bin/sh
# Relocate the fork image's persistent paths into the single HA /data volume.
# Runs BEFORE the image's own 01-postgres-init / 02-app-init (lexical order:
# 00 < 01 < 02), so the symlinks are already in place when those run.
set -e

mkdir -p /data/db /data/uploads

# Postgres: initdb (run as `postgres`) requires the data dir to be owned by
# postgres and mode 700. Chown the symlink TARGET, not just the link.
if [ ! -L /var/lib/postgresql/17/main ]; then
  rm -rf /var/lib/postgresql/17/main
  ln -s /data/db /var/lib/postgresql/17/main
fi
chown postgres:postgres /data/db
chmod 700 /data/db

# Uploads: backend writes here as user `inker`.
if [ ! -L /app/uploads ]; then
  rm -rf /app/uploads
  ln -s /data/uploads /app/uploads
fi
# Pre-create the upload subdirs on the REAL target and chown them recursively.
# The image's 02-app-init does `mkdir -p /app/uploads/...` (as root) and the
# backend service does `chown -R inker:inker /app/uploads`, but that chown is
# given the /app/uploads *symlink* and `chown -R` (default -P) does NOT traverse
# a symlink argument — so without this the subdirs stay root-owned and the
# non-root `inker` backend cannot write screens/captures. mkdir -p here is
# idempotent, so 02-app-init's later mkdir is a no-op and ownership sticks.
mkdir -p /data/uploads/screens /data/uploads/firmware /data/uploads/widgets \
         /data/uploads/captures /data/uploads/drawings
chown -R inker:inker /data/uploads

echo "[ha] Relocated Postgres data -> /data/db, uploads -> /data/uploads"
