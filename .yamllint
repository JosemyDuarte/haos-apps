---
extends: default

rules:
  # Long descriptive strings (translations, repo metadata) are fine.
  line-length: disable
  # GitHub Actions uses `on:` as a key; don't treat it as a truthy value.
  truthy:
    check-keys: false
  comments:
    require-starting-space: true
    min-spaces-from-content: 1
  comments-indentation: disable
